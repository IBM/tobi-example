CREATE OR REPLACE TABLE CUSTTBL (
  CUSTOMER_ID FOR COLUMN CUSTID CHAR(6) NOT NULL,
  CUSTOMER_NAME FOR COLUMN CUSTNM VARCHAR(50) NOT NULL DEFAULT '',
  PRIMARY KEY (CUSTID)
);

LABEL ON TABLE CUSTTBL
  IS 'Customer Table';

LABEL ON COLUMN CUSTTBL (
  CUSTID IS 'Customer ID',
  CUSTNM IS 'Customer Name'
);